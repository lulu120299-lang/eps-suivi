      ],
      "parties": [
        {
          "id": "p1774087483132mk1",
          "titre": "Echauffement",
          "objectif": "Échauffer son corps et monter progressive de sa température corporelle",
          "consignes": "Donner des mentions de légendes en ajoutant une consignes (exemple : montée de genou, talon fesses, course…) et identifier autour de nous quelques chose se référant à la légende et exécuter la consignes",
